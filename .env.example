# Database
DATABASE_URL=postgresql://user:password@localhost:5432/dlr

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# NextAuth
NEXTAUTH_SECRET=change-me-to-a-random-32-char-string
NEXTAUTH_URL=http://localhost:3000

# Telnyx
TELNYX_API_KEY=KEY...
TELNYX_PUBLIC_KEY=...   # Ed25519 public key from Telnyx dashboard (for webhook verification)
TELNYX_MESSAGING_PROFILE_ID=...  # optional, set per phone number or globally

# Webhook relay (local dev only)
DLR_RELAY_TOKEN=...             # openssl rand -hex 16
DLR_RELAY_HOST=wss://dlr-relay.fly.dev

# Outbound email (password reset, dealer invites)
# Uses the Resend HTTP API — no Gmail App Passwords or SMTP required.
# Sign up at resend.com, verify dlr-sms.com as a sending domain, then
# create an API key. See docs/password-reset-email.md for full steps.
#
# EMAIL_FROM must be a bare email address — NOT "Display Name <addr>" format.
# Each email function prepends its own display name (e.g. "DLR Security <...>").
#
RESEND_API_KEY=re_...
EMAIL_FROM=brian@dlr-sms.com

# Legacy — SMTP_URL is no longer used. Remove from Vercel after confirming
# Resend works in production.
# SMTP_URL=smtps://brian%40dlr-sms.com:GOOGLE_APP_PASSWORD@smtp.gmail.com:465

# Dealer Outreach CRM (admin/Brian-only — /admin/outreach)
# Real prospect demo-invite emails are sent ONLY when this is exactly "true".
# When unset/false: previews + test-to-Brian still work; real sends are logged
# as dry_run and never leave the building. Test emails always go to brian@dlr-sms.com.
OUTREACH_SEND_ENABLED=false
# Max prospects in one batch send. Defaults to 25 if unset; sends never exceed it.
OUTREACH_MAX_BATCH_SIZE=25
# Outreach sender identity (overrides the built-in defaults).
OUTREACH_FROM_NAME=Brian Hardy | Dead Lead Revival
OUTREACH_REPLY_TO=brian@dlr-sms.com
# CAN-SPAM postal address printed in every outreach email footer. REQUIRED for
# live sends — if unset/blank, real sends are blocked (logged as skipped) so a
# placeholder address can never ship. Use a real mailing address.
OUTREACH_BUSINESS_ADDRESS=123 Example St, Saratoga Springs, UT 84045
