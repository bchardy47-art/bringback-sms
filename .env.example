# Database
DATABASE_URL=postgresql://user:password@localhost:5432/dlr

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# NextAuth
NEXTAUTH_SECRET=change-me-to-a-random-32-char-string
NEXTAUTH_URL=http://localhost:3000

# Telnyx
TELNYX_API_KEY=KEY...
TELNYX_PUBLIC_KEY=...   # Ed25519 public key from Telnyx dashboard (for webhook verification)
TELNYX_MESSAGING_PROFILE_ID=...  # optional, set per phone number or globally

# Webhook relay (local dev only)
DLR_RELAY_TOKEN=...             # openssl rand -hex 16
DLR_RELAY_HOST=wss://dlr-relay.fly.dev

# Outbound email (password reset, dealer invites)
# Uses the Resend HTTP API — no Gmail App Passwords or SMTP required.
# Sign up at resend.com, verify dlr-sms.com as a sending domain, then
# create an API key. See docs/password-reset-email.md for full steps.
#
# EMAIL_FROM must be a bare email address — NOT "Display Name <addr>" format.
# Each email function prepends its own display name (e.g. "DLR Security <...>").
#
RESEND_API_KEY=re_...
EMAIL_FROM=brian@dlr-sms.com

# Legacy — SMTP_URL is no longer used. Remove from Vercel after confirming
# Resend works in production.
# SMTP_URL=smtps://brian%40dlr-sms.com:GOOGLE_APP_PASSWORD@smtp.gmail.com:465
